+type UiDialogReq = {
+  kind: "confirm" | "prompt" | "alert";
+  message: string;
+  value: string;
+  resolve: (v: any) => void;
+};
+let _uiSetDialog: ((d: UiDialogReq | null) => void) | null = null;
+function uiConfirm(message: string): Promise<boolean> {
+  return new Promise((resolve) =>
+    _uiSetDialog
+      ? _uiSetDialog({ kind: "confirm", message, value: "", resolve })
+      : resolve(false),
+  );
+}
+function uiPrompt(message: string, def = ""): Promise<string | null> {
+  return new Promise((resolve) =>
+    _uiSetDialog
+      ? _uiSetDialog({ kind: "prompt", message, value: def, resolve })
+      : resolve(null),
+  );
+}
+function uiAlert(message: string): Promise<void> {
+  return new Promise((resolve) =>
+    _uiSetDialog
+      ? _uiSetDialog({ kind: "alert", message, value: "", resolve })
+      : resolve(),
+  );
+}
+function DialogHost() {
+  const [d, setD] = useState<UiDialogReq | null>(null);
+  useEffect(() => {
+    _uiSetDialog = setD;
+    return () => {
+      _uiSetDialog = null;
+    };
+  }, []);
+  if (!d) return null;
+  const close = (v: any) => {
+    d.resolve(v);
+    setD(null);
+  };
+  const cancelVal = d.kind === "confirm" ? false : d.kind === "prompt" ? null : undefined;
+  const okVal = d.kind === "confirm" ? true : d.kind === "prompt" ? d.value : undefined;
+  return (
+    <div
+      className="fixed inset-0 z-[100] flex items-center justify-center bg-black/40 px-4"
+      onClick={() => close(cancelVal)}
+    >
+      <div
+        dir="rtl"
+        className="bg-white rounded-md shadow-xl w-full max-w-md p-6"
+        onClick={(e) => e.stopPropagation()}
+      >
+        <p className="text-sm text-slate-700 mb-4 text-right whitespace-pre-line leading-7">{d.message}</p>
+        {d.kind === "prompt" && (
+          <input
+            autoFocus
+            value={d.value}
+            onChange={(e) => setD((p) => (p ? { ...p, value: e.target.value } : p))}
+            onKeyDown={(e) => {
+              if (e.key === "Enter") close(d.value);
+            }}
+            className="w-full h-11 border border-slate-300 rounded px-3 text-right focus:outline-none focus:border-[color:var(--eyenak-teal)] mb-4"
+          />
+        )}
+        <div className="flex items-center gap-2 justify-end">
+          {d.kind !== "alert" && (
+            <button
+              onClick={() => close(cancelVal)}
+              className="h-10 px-4 rounded border border-slate-300 text-slate-600 text-sm hover:bg-slate-50"
+            >
+              إلغاء
+            </button>
+          )}
+          <button
+            onClick={() => close(okVal)}
+            className="h-10 px-5 rounded bg-[color:var(--eyenak-teal)] text-white text-sm font-bold hover:opacity-90"
+          >
+            {d.kind === "confirm" ? "تأكيد" : "موافق"}
+          </button>
+        </div>
+      </div>
+    </div>
+  );
+}
